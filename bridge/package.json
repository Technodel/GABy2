{
  "name": "suny-bridge",
  "version": "1.0.0",
  "description": "SUNy Bridge — local agent that connects your machine to the SUNy VPS",
  "private": false,
  "main": "dist/index.js",
  "bin": {
    "suny-bridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "pack": "npm run build && npm pack",
    "build:exe": "npm run build && pkg . --targets node18-win-x64 --output dist/suny-bridge.exe"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [],
    "targets": [
      "node18-win-x64"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "suny",
    "coding-assistant",
    "bridge",
    "ai",
    "sandbox"
  ],
  "license": "MIT",
  "homepage": "https://suny.technodel.tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/Technodel/SUNy"
  },
  "bugs": {
    "url": "https://github.com/Technodel/SUNy/issues"
  },
  "dependencies": {
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
