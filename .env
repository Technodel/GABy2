# GABy environment variables — copy to .env and fill in real values

# Admin login password (single super-admin)
GABY_ADMIN_PASSWORD=301088

# Server port
GABY_PORT=3500

# SQLite database path
GABY_DB_PATH=./data/gaby.db

# JWT signing secret — set a long random string in production
GABY_SECRET_JWT=dev_secret_for_local_testing_only_change_in_prod

# Origin allowed for CORS (your VPS domain)
GABY_ALLOWED_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
