# SUNy environment variables — copy to .env and fill in real values

# ── Server ──────────────────────────────────────────────────────────────────────

# Server port (default: 3000)
SUNY_PORT=3000

# Node environment — "production" or "development"
NODE_ENV=production

# SQLite database path — use a persistent volume in Docker
SUNY_DB_PATH=./data/suny.db

# ── Authentication ──────────────────────────────────────────────────────────────

# Admin login password (single super-admin). Change immediately on first login.
SUNY_ADMIN_PASSWORD=change_this_now

# JWT signing secret — set a long random string in production (minimum 32 chars)
SUNY_SECRET_JWT=change_this_to_a_long_random_secret_string_min_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────────────

# Origin allowed for CORS — your VPS domain or frontend URL
SUNY_ALLOWED_ORIGIN=https://suny.technodel.tech

# ── API Keys (seeded on first run) ──────────────────────────────────────────────

# Groq API key — used for free mode (primary). Get one at https://console.groq.com
# SUNY_GROQ_KEY=gsk_your_groq_key_here

# OpenRouter API key — fallback for free mode. Get one at https://openrouter.ai/keys
# SUNY_OPENROUTER_KEY=sk-or-your_openrouter_key_here

# DeepSeek API key — used for fast and pro modes. Get one at https://platform.deepseek.com
# SUNY_DEEPSEEK_KEY=sk-your_deepseek_key_here
