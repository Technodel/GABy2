# SUNy environment variables — copy to .env and fill in real values

# Admin login password (single super-admin)
SUNY_ADMIN_PASSWORD=301088

# Server port
SUNY_PORT=3000

# SQLite database path
SUNY_DB_PATH=./data/suny.db

# JWT signing secret — set a long random string in production
SUNY_SECRET_JWT=change_this_to_a_long_random_secret_string

# Origin allowed for CORS (your VPS domain)
SUNY_ALLOWED_ORIGIN=https://suny.technodel.tech

# Node environment
NODE_ENV=production
